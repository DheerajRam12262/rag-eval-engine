# Copy to .env and fill in. .env is gitignored. Everything runs offline WITHOUT these set;
# they are only needed to swap in real API/service backends (see config/*.yaml).

# --- LLM generation / judge (optional; only for the `llm` extra) ---
# Provider one of: offline | anthropic | openai
RAG_LLM_PROVIDER=offline
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Pin a model SNAPSHOT (not a floating alias) for reproducibility.
RAG_GENERATION_MODEL=claude-sonnet-4-6
RAG_JUDGE_MODEL=claude-opus-4-8

# --- Vector store (optional; only for the `qdrant` extra) ---
# Backend one of: memory | qdrant
RAG_VECTOR_BACKEND=memory
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Embeddings (optional; only for the `embeddings` extra) ---
# Backend one of: hashing | sentence-transformers
RAG_EMBEDDER_BACKEND=hashing
RAG_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# --- Reproducibility ---
RAG_SEED=42
